{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg":             "#0e091d",
    "bg_panel":       "#12101f",
    "bg_highlight":   "#1a1520",
    "fg":             "#14B9B5",
    "fg_dim":         "#11AEB3",
    "fg_muted":       "#6C032C",
    "border":         "#2a153c",
    "orange_red":     "#E20342",
    "orange":         "#FF7F41",
    "yellow":         "#ffbe74",
    "green":          "#c8e967",
    "cyan":           "#14B9B5",
    "cyan_bright":    "#04C5F0",
    "cyan_light":     "#11AEB3",
    "purple":         "#9147a8",
    "green_fn":       "#7cd699"
  },
  "theme": {
    "primary": "cyan",
    "secondary": "orange_red",
    "accent": "orange",
    "error": "orange_red",
    "warning": "orange",
    "success": "green",
    "info": "cyan",
    "text": "fg",
    "textMuted": "fg_muted",
    "background": "bg",
    "backgroundPanel": "bg_panel",
    "backgroundElement": "bg_panel",
    "border": "border",
    "borderActive": "cyan_light",
    "borderSubtle": "fg_muted",
    "diffAdded": "green",
    "diffRemoved": "orange_red",
    "diffContext": "bg_panel",
    "diffHunkHeader": "fg_muted",
    "diffHighlightAdded": "green",
    "diffHighlightRemoved": "orange_red",
    "diffAddedBg": "#0e1a0e",
    "diffRemovedBg": "#1d0a1a",
    "diffContextBg": "bg_highlight",
    "diffLineNumber": "fg_muted",
    "diffAddedLineNumberBg": "#0e1a0e",
    "diffRemovedLineNumberBg": "#1d0a1a",
    "markdownText": "fg_dim",
    "markdownHeading": "orange_red",
    "markdownLink": "cyan",
    "markdownLinkText": "cyan_bright",
    "markdownCode": "cyan",
    "markdownBlockQuote": "fg",
    "markdownEmph": "orange",
    "markdownStrong": "orange_red",
    "markdownHorizontalRule": "fg_muted",
    "markdownListItem": "orange_red",
    "markdownListEnumeration": "cyan",
    "markdownImage": "cyan",
    "markdownImageText": "cyan_bright",
    "markdownCodeBlock": "fg",
    "syntaxComment": "fg_muted",
    "syntaxKeyword": "purple",
    "syntaxFunction": "green_fn",
    "syntaxVariable": "cyan_light",
    "syntaxString": "orange",
    "syntaxNumber": "yellow",
    "syntaxType": "orange_red",
    "syntaxOperator": "green",
    "syntaxPunctuation": "fg_dim"
  }
}
